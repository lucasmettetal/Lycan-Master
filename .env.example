# URL du backend appelée par le frontend (navigateur ou app mobile)
# Dev local     → http://localhost:3001
# IP Wi-Fi      → http://192.168.1.XX:3001
# Codespace     → https://XXXXX-3001.app.github.dev
# Production    → https://TON_BACKEND_URL
VITE_API_URL=http://localhost:3001

# URL publique de l'app web — utilisée pour les QR codes d'invitation joueur.
# OBLIGATOIRE si tu utilises l'APK Android (Capacitor), sinon le QR code
# pointerait vers capacitor://localhost qui n'est pas accessible depuis iPhone.
# Laisser vide en dev : window.location.origin sera utilisé automatiquement.
# VITE_PUBLIC_APP_URL=https://lycan-master.ton-domaine.fr
