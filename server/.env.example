# Port d'écoute du serveur
PORT=3001

# URL du frontend autorisée par CORS
# Dev local     → http://localhost:5173
# IP Wi-Fi      → http://192.168.1.XX:5173
# Codespace     → https://XXXXX-5173.app.github.dev
# Production    → https://TON_FRONTEND_URL
FRONTEND_URL=http://localhost:5173

# Chemin du fichier de persistance JSON
# Dev           → ./games.json
# Production    → /data/games.json (volume persistant Railway/Render)
DATA_FILE_PATH=./games.json
